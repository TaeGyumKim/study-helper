# LMS 계정 (최초 실행 시 CUI에서 입력하면 자동 저장됨)
LMS_USER_ID=
LMS_PASSWORD=

# ── 다운로드 설정 (최초 실행 시 설정 화면에서 입력하면 자동 저장됨) ──────────────

# 다운로드 경로 (비워두면 OS 기본 다운로드 폴더 사용)
# Docker: /data/downloads / macOS: ~/Downloads / Windows: C:\Users\사용자명\Downloads
DOWNLOAD_DIR=

# 다운로드 규칙: video(영상만) / audio(음성만) / both(영상+음성)
DOWNLOAD_RULE=

# STT 텍스트 변환 사용 여부: true / false (DOWNLOAD_RULE=video이면 적용 안 됨)
STT_ENABLED=

# Whisper 모델 크기: tiny / base / small / medium / large
# 작을수록 빠르지만 정확도 낮음 (기본값: base)
WHISPER_MODEL=base

# STT 언어: ko(한국어) / en(영어) / 빈 값(자동 감지)
STT_LANGUAGE=ko

# ── AI 요약 설정 ──────────────────────────────────────────────────────────────

# AI 요약 사용 여부: true / false
AI_ENABLED=

# AI 에이전트 종류: gemini / openai
AI_AGENT=

# Gemini 모델 (기본값: gemini-2.5-flash / 무료 티어 지원)
# gemini-2.5-flash / gemini-2.0-flash / gemini-1.5-flash / gemini-1.5-pro
GEMINI_MODEL=

# 추가 요약 지시사항 (기본 프롬프트에 추가됨, 비워두면 기본값만 사용)
SUMMARY_PROMPT_EXTRA=

# API 키 (AI_AGENT에 맞는 키만 입력)
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ── 텔레그램 알림 설정 ──────────────────────────────────────────────────────────

# 텔레그램 알림 사용 여부: true / false
TELEGRAM_ENABLED=

# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=

# 수신자 Chat ID (@userinfobot에서 확인)
TELEGRAM_CHAT_ID=

# AI 요약 전송 성공 후 파일 자동 삭제: true / false
TELEGRAM_AUTO_DELETE=
